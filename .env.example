# ═══════════════════════════════════════════════════════════════
# Antigravity Forensics — Environment Configuration
# ═══════════════════════════════════════════════════════════════
# Copy this file to .env and customize values.
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════

# ── Security ─────────────────────────────────────────────────
# CRITICAL: Change this in production!
JWT_SECRET_KEY=change_me_to_a_random_64_char_string

# ── Database ─────────────────────────────────────────────────
DATABASE_PATH=/app/data/cases.db
CORE_DB_PATH=/app/data/core_forensics.db

# ── Forensics Engine ─────────────────────────────────────────
MEMORY_DUMP=/app/evidence/msedge.DMP
TOOLS_DIR=/app/tools
OUTPUT_DIR=/app/output

# ── API Configuration ────────────────────────────────────────
API_BASE_URL=http://localhost:8001
API_PORT=8001

# ── CORS ─────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://localhost,http://localhost:80,http://localhost:5173

# ── Mode ─────────────────────────────────────────────────────
# Set to "false" to enable real action execution
SIMULATE_MODE=true

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Rate Limiting ────────────────────────────────────────────
# Hunt queries: max requests per 10-second window per user
HUNT_RATE_LIMIT=10
# Ingestion: max events per second per source
INGEST_RATE_LIMIT=100

# ── Circuit Breaker ──────────────────────────────────────────
# Consecutive failures before circuit opens
CB_FAILURE_THRESHOLD=3
# Seconds before circuit allows test request
CB_COOLDOWN_SECONDS=5
